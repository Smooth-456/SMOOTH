			if part then
				local pos, onScreen = cam:WorldToViewportPoint(part.Position)
				if onScreen then
					if wallCheck then
						local rParams = RaycastParams.new() rParams.FilterType = Enum.RaycastFilterType.Exclude rParams.FilterDescendantsInstances = {LP.Character, cam}
						local res = workspace:Raycast(cam.CFrame.Position, (part.Position - cam.CFrame.Position).Unit * 500, rParams)
						if res and res.Instance and not res.Instance:IsDescendantOf(pl.Character) then onScreen = false end
					end
					if onScreen then
						local mousePos = UIS:GetMouseLocation() local d = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
						if d < dist then dist, closest = d, part end
					end
				end
			end
		end
	end
	return closest
end

table.insert(conns, RS.RenderStepped:Connect(function()
	if aimEnabled then
		local target = getClosestPlayer()
		if target and workspace.CurrentCamera then
			if strongLock then
				workspace.CurrentCamera.CFrame = CFrame.new(workspace.CurrentCamera.CFrame.Position, target.Position)
			else
				local currentCF = workspace.CurrentCamera.CFrame
				local targetCF = CFrame.new(currentCF.Position, target.Position)
				workspace.CurrentCamera.CFrame = currentCF:Lerp(targetCF, 1 / aimSmooth)
			end
		end
	end
end))
