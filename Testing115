local toraScripts = {}
local HttpService = game:GetService("HttpService")

local function fetchAllGitHubScripts()
    local headers = { ["User-Agent"] = "RobloxStudio/1.0" }
    local response = request({
        Url = "https://api.github.com/repos/gumanba/Scripts/git/trees/main?recursive=1",
        Method = "GET",
        Headers = headers
    })
    
    if response and response.StatusCode == 200 then
        return HttpService:JSONDecode(response.Body)
    else
        error("API Failed: " .. tostring(response and response.StatusCode or "No Response"))
    end
end

local success, data = pcall(fetchAllGitHubScripts)

