local lastClick = 0
local clearBtn = rowBtn("🧹 Clear Other Scripts (Double Click)", homeTab, function(b)
    local currentTick = tick()
    if currentTick - lastClick < 0.4 then 
        b.Text = "  ⚠️ Clearing scripts..."
        b.BackgroundColor3 = Color3.fromRGB(200, 140, 20)
        
        task.spawn(function()
            local targetStorage = game:GetService("CoreGui")
            if not pcall(function() local _ = targetStorage.Name end) then
                targetStorage = game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui")
            end
            
            for _, gui in ipairs(targetStorage:GetChildren()) do
                if gui:IsA("ScreenGui") and gui.Name ~= "SmoothScriptUI" then
                    pcall(function() gui:Destroy() end)
                end
            end
            
            for key, _ in pairs(getgenv()) do
                if key ~= "HybridSettings" and key ~= "CustomToraAutomation" then
                    pcall(function() getgenv()[key] = nil end)
                end
            end
            
            task.wait(0.5)
            b.Text = "  ✅ Cleared Other Scripts!"
            b.BackgroundColor3 = Color3.fromRGB(34, 139, 34)
            task.wait(2)
            b.Text = "  🧹 Clear Other Scripts (Double Click)"
            b.BackgroundColor3 = Color3.fromRGB(24, 36, 66) 
        end)
    else
        b.Text = "  🖱️ Double Click to Confirm!"
        task.spawn(function()
            task.wait(1.5)
            if tick() - lastClick >= 1.5 then
                b.Text = "  🧹 Clear Other Scripts (Double Click)"
            end
        end)
    end
    lastClick = currentTick
end)
