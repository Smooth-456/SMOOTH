local function handleESP(v)
	espEnabled = v
	for _, pl in pairs(P:GetPlayers()) do
		if pl.Character then
			for _, child in pairs(pl.Character:GetDescendants()) do
				if child:IsA("BoxHandleAdornment") and child.Name == "SmoothScriptESP" then
					pcall(function() child:Destroy() end)
				end
			end
		end
	end
	table.clear(espBoxes)

	if not espEnabled then return end

	task.spawn(function()
		while espEnabled do
			for pl, b in pairs(espBoxes) do
				if not pl.Character or not pl.Character:FindFirstChild("HumanoidRootPart") or not b.Parent then
					if b then pcall(function() b:Destroy() end) end
					espBoxes[pl] = nil
				end
			end
			for _, pl in pairs(P:GetPlayers()) do
				if pl ~= LP and pl.Character and pl.Character:FindFirstChild("HumanoidRootPart") and not espBoxes[pl] then
					pcall(function()
						local b = Instance.new("BoxHandleAdornment")
						b.Name = "SmoothScriptESP"
						b.Size, b.AlwaysOnTop, b.ZIndex, b.Color3, b.Transparency, b.Adornee, b.Parent =
							Vector3.new(4,5,4), true, 10, GLOW_C, 0.5, pl.Character.HumanoidRootPart, pl.Character.HumanoidRootPart
						espBoxes[pl] = b
					end)
				end
			end
			task.wait(0.5)
		end
	end)
end
