local function adaptCtrl(lbl, cVals, dfVal, p, cb)
	local cur = dfVal
	local f = Instance.new("Frame", p)
	f.Size, f.BackgroundColor3 = UDim2.new(1,-4,0,38), BT_C
	Instance.new("UICorner", f).CornerRadius = UDim.new(0,6)
	local cbn = Instance.new("TextButton", f)
	cbn.Size, cbn.BackgroundTransparency, cbn.TextColor3, cbn.Font, cbn.TextSize, cbn.TextXAlignment =
		UDim2.new(1,0,1,0), 1, TX_C, Enum.Font.SourceSansBold, 14, Enum.TextXAlignment.Left
	cbn.Text = "  " .. lbl .. ": " .. tostring(cur)
	local inp = Instance.new("TextBox", f)
	inp.Size, inp.Position, inp.BackgroundColor3, inp.TextColor3, inp.Font, inp.TextSize, inp.Text, inp.Visible =
		UDim2.new(0,60,0,24), UDim2.new(1,-68,0,7), BG_C, NUM_C, Enum.Font.SourceSansBold, 13, tostring(dfVal), false
	Instance.new("UICorner", inp).CornerRadius = UDim.new(0,4)
	
	cbn.Activated:Connect(function()
		if inputMode == "CYCLE" then
			local n = 1
			for i, v in ipairs(cVals) do if v == cur then n = i + 1 break end end
			if n > #cVals then n = 1 end
			cur = cVals[n] cb(cur)
			cbn.Text = "  " .. lbl .. ": " .. tostring(cur)
		end
	end)
	inp.FocusLost:Connect(function()
		local num = tonumber(inp.Text)
		if num then cur = num cb(num) else inp.Text = tostring(cur) end
	end)
	table.insert(uiReg, function()
		if inputMode == "CYCLE" then
			cbn.Text, cbn.TextXAlignment, inp.Visible = "  " .. lbl .. ": " .. tostring(cur), Enum.TextXAlignment.Left, false
		else
			cbn.Text, cbn.TextXAlignment, inp.Visible = "  " .. lbl .. ":", Enum.TextXAlignment.Left, true
			inp.Text = tostring(cur)
		end
	end)
end

